# =============================================================================
# AI Infrastructure Planner - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and update the values
# cp .env.production.example .env.production
# =============================================================================

# =============================================================================
# PORT CONFIGURATION (Fixed Random Ports)
# =============================================================================
# These ports avoid conflicts with other services on the server
# Change these if they conflict with your existing services

FRONTEND_PORT=3100
BACKEND_PORT=8100
POSTGRES_PORT=5433
REDIS_PORT=6380

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=ai_infrastructure_prod
POSTGRES_USER=ai_infra_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis doesn't need additional config, uses the port above

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Secret key for JWT token signing - MUST CHANGE IN PRODUCTION
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_YOUR_SECRET_KEY_GENERATE_WITH_OPENSSL_RAND_HEX_32

# OpenAI API Key - Required for AI analysis features
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# CORS Origins - Comma-separated list of allowed origins
# Include your domain(s) here
CORS_ORIGINS=http://your-domain.com,http://localhost:3100

# Environment
ENVIRONMENT=production

# API Version Prefix
API_V1_PREFIX=/api/v1

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Backend API URL for frontend to connect
# Update this to your server's domain or IP
VITE_API_BASE_URL=http://your-server-ip:8100/api/v1
