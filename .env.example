DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_infrastructure
REDIS_URL=redis://localhost:6379/0
# OpenAI API Key - Required for AI analysis features
# Replace 'your-openai-api-key-here' with a valid OpenAI API key
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
SECRET_KEY=your-secret-key-for-jwt-tokens-change-in-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

POSTGRES_DB=ai_infrastructure
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

VITE_API_BASE_URL=http://localhost:8000/api/v1
